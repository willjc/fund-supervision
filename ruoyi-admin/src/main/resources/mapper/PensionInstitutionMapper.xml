    <sql id="selectPensionInstitutionVo">
        select institution_id, institution_name, credit_code, registered_capital,
               registered_address, street, actual_address, legal_person, contact_person,
               contact_phone, contact_email, business_scope, institution_type,
               bed_count, district_code, area_code, institution_nature, care_levels, medical_condition,
               rating_level, price_range_min, price_range_max, free_trial,
               fee_range, established_date, organizer, responsible_name,
               responsible_id_card, responsible_address, responsible_phone, record_number,
               fixed_assets, business_license, approval_certificate, supervision_agreement,
               bank_account, supervise_account, status, apply_time, approve_time,
               approve_user, approve_remark, blacklist_flag, create_by, create_time,
               update_by, update_time, remark
        from pension_institution
    </sql>

    <select id="selectPensionInstitutionList" parameterType="PensionInstitution" resultMap="PensionInstitutionResult">
        <include refid="selectPensionInstitutionVo"/>
        <where>
            <!-- 数据权限过滤: 如果传入了currentUserId,则只查询该用户有权限的机构 -->
            <if test="currentUserId != null">
                and institution_id in (
                    select institution_id from sys_user_institution where user_id = #{currentUserId}
                )
            </if>
            <if test="institutionName != null and institutionName != ''"> and institution_name like concat('%', #{institutionName}, '%')</if>
            <if test="creditCode != null and creditCode != ''"> and credit_code = #{creditCode}</if>
            <if test="contactPerson != null and contactPerson != ''"> and contact_person like concat('%', #{contactPerson}, '%')</if>
            <if test="contactPhone != null and contactPhone != ''"> and contact_phone = #{contactPhone}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
            <if test="institutionType != null and institutionType != ''"> and institution_type = #{institutionType}</if>

            <!-- 新增筛选条件 -->
            <if test="districtCode != null and districtCode != ''"> and district_code = #{districtCode}</if>
            <if test="areaCode != null and areaCode != ''"> and area_code = #{areaCode}</if>
            <if test="institutionNature != null and institutionNature != ''"> and institution_nature = #{institutionNature}</if>
            <if test="medicalCondition != null and medicalCondition != ''"> and medical_condition = #{medicalCondition}</if>
            <if test="ratingLevel != null"> and rating_level = #{ratingLevel}</if>
            <if test="freeTrial != null and freeTrial != ''"> and free_trial = #{freeTrial}</if>

            <!-- 收住类型多选筛选: careLevels字段存储逗号分隔的值,如"1,2,3" -->
            <if test="careLevels != null and careLevels != ''">
                and (
                <foreach collection="careLevels.split(',')" item="level" separator=" or ">
                    FIND_IN_SET(#{level}, care_levels)
                </foreach>
                )
            </if>

            <!-- 价格区间筛选 -->
            <if test="priceRangeMin != null">
                and price_range_max &gt;= #{priceRangeMin}
            </if>
            <if test="priceRangeMax != null">
                and price_range_min &lt;= #{priceRangeMax}
            </if>

            <!-- 区域代码多选筛选 -->
            <if test="areaCodes != null and areaCodes.size() > 0">
                and area_code in
                <foreach collection="areaCodes" item="areaCode" open="(" separator="," close=")">
                    #{areaCode}
                </foreach>
            </if>

            <!-- 街道名称多选筛选 -->
            <if test="streetNames != null and streetNames.size() > 0">
                and street in
                <foreach collection="streetNames" item="streetName" open="(" separator="," close=")">
                    #{streetName}
                </foreach>
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPensionInstitutionByInstitutionId" parameterType="Long" resultMap="PensionInstitutionResult">
        <include refid="selectPensionInstitutionVo"/>
        where institution_id = #{institutionId}
    </select>

