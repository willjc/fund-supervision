<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.InstitutionBlacklistMapper">

    <resultMap type="InstitutionBlacklist" id="InstitutionBlacklistResult">
        <result property="id"               column="id"                />
        <result property="institutionId"    column="institution_id"    />
        <result property="institutionName"  column="institution_name"  />
        <result property="blacklistType"    column="blacklist_type"    />
        <result property="reason"           column="reason"            />
        <result property="status"           column="status"            />
        <result property="addTime"          column="add_time"          />
        <result property="removeTime"       column="remove_time"       />
        <result property="handleOpinion"    column="handle_opinion"    />
        <result property="createBy"         column="create_by"         />
        <result property="createTime"       column="create_time"       />
        <result property="updateBy"         column="update_by"         />
        <result property="updateTime"       column="update_time"       />
        <result property="remark"           column="remark"            />
    </resultMap>

    <sql id="selectInstitutionBlacklistVo">
        select id, institution_id, institution_name, blacklist_type, reason, status,
               add_time, remove_time, handle_opinion, create_by, create_time,
               update_by, update_time, remark
        from institution_blacklist
    </sql>

    <select id="selectInstitutionBlacklistList" parameterType="InstitutionBlacklist" resultMap="InstitutionBlacklistResult">
        <include refid="selectInstitutionBlacklistVo"/>
        <where>
            <if test="institutionId != null">and institution_id = #{institutionId}</if>
            <if test="institutionName != null and institutionName != ''">and institution_name like concat('%', #{institutionName}, '%')</if>
            <if test="blacklistType != null and blacklistType != ''">and blacklist_type = #{blacklistType}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by add_time desc
    </select>

    <select id="selectInstitutionBlacklistById" parameterType="Long" resultMap="InstitutionBlacklistResult">
        <include refid="selectInstitutionBlacklistVo"/>
        where id = #{id}
    </select>

    <select id="selectByInstitutionId" parameterType="Long" resultMap="InstitutionBlacklistResult">
        <include refid="selectInstitutionBlacklistVo"/>
        where institution_id = #{institutionId}
        order by add_time desc
        limit 1
    </select>

    <insert id="insertInstitutionBlacklist" parameterType="InstitutionBlacklist" useGeneratedKeys="true" keyProperty="id">
        insert into institution_blacklist
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="institutionId != null">institution_id,</if>
            <if test="institutionName != null and institutionName != ''">institution_name,</if>
            <if test="blacklistType != null and blacklistType != ''">blacklist_type,</if>
            <if test="reason != null and reason != ''">reason,</if>
            <if test="status != null">status,</if>
            <if test="addTime != null">add_time,</if>
            <if test="removeTime != null">remove_time,</if>
            <if test="handleOpinion != null and handleOpinion != ''">handle_opinion,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="institutionId != null">#{institutionId},</if>
            <if test="institutionName != null and institutionName != ''">#{institutionName},</if>
            <if test="blacklistType != null and blacklistType != ''">#{blacklistType},</if>
            <if test="reason != null and reason != ''">#{reason},</if>
            <if test="status != null">#{status},</if>
            <if test="addTime != null">#{addTime},</if>
            <if test="removeTime != null">#{removeTime},</if>
            <if test="handleOpinion != null and handleOpinion != ''">#{handleOpinion},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateInstitutionBlacklist" parameterType="InstitutionBlacklist">
        update institution_blacklist
        <trim prefix="SET" suffixOverrides=",">
            <if test="institutionId != null">institution_id = #{institutionId},</if>
            <if test="institutionName != null and institutionName != ''">institution_name = #{institutionName},</if>
            <if test="blacklistType != null and blacklistType != ''">blacklist_type = #{blacklistType},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="status != null">status = #{status},</if>
            <if test="addTime != null">add_time = #{addTime},</if>
            <if test="removeTime != null">remove_time = #{removeTime},</if>
            <if test="handleOpinion != null">handle_opinion = #{handleOpinion},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <update id="removeFromBlacklist" parameterType="Long">
        update institution_blacklist
        set status = '2',
            remove_time = sysdate(),
            update_time = sysdate()
        where id = #{id}
    </update>

    <delete id="deleteInstitutionBlacklistById" parameterType="Long">
        delete from institution_blacklist where id = #{id}
    </delete>

    <delete id="deleteInstitutionBlacklistByIds" parameterType="Long">
        delete from institution_blacklist where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
