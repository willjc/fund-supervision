<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.MealFeeConfigMapper">

    <resultMap type="com.ruoyi.domain.pension.MealFeeConfig" id="MealFeeConfigResult">
        <result property="configId"       column="config_id"       />
        <result property="institutionId"  column="institution_id"  />
        <result property="mealLevel"      column="meal_level"      />
        <result property="mealLevelCode"  column="meal_level_code" />
        <result property="price"          column="price"           />
        <result property="mealDescription" column="meal_description"/>
        <result property="isAvailable"    column="is_available"    />
        <result property="sortOrder"      column="sort_order"      />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
        <result property="institutionName" column="institution_name"/>
    </resultMap>

    <sql id="selectMealFeeConfigVo">
        select m.config_id, m.institution_id, m.meal_level, m.meal_level_code, m.price,
               m.meal_description, m.is_available, m.sort_order,
               m.create_by, m.create_time, m.update_by, m.update_time, m.remark,
               p.institution_name
        from meal_fee_config m
        left join pension_institution p on m.institution_id = p.institution_id
    </sql>

    <select id="selectMealFeeConfigList" parameterType="com.ruoyi.domain.pension.MealFeeConfig" resultMap="MealFeeConfigResult">
        <include refid="selectMealFeeConfigVo"/>
        <where>
            <if test="institutionId != null">
                AND m.institution_id = #{institutionId}
            </if>
            <if test="mealLevel != null and mealLevel != ''">
                AND m.meal_level like concat('%', #{mealLevel}, '%')
            </if>
            <if test="mealLevelCode != null and mealLevelCode != ''">
                AND m.meal_level_code = #{mealLevelCode}
            </if>
            <if test="isAvailable != null and isAvailable != ''">
                AND m.is_available = #{isAvailable}
            </if>
            <!-- 数据权限过滤 -->
            <if test="currentUserId != null">
                AND m.institution_id IN (
                    SELECT institution_id FROM sys_user_institution WHERE user_id = #{currentUserId}
                )
            </if>
        </where>
        order by m.sort_order, m.institution_id, m.meal_level_code
    </select>

    <select id="selectMealFeeConfigByConfigId" parameterType="Long" resultMap="MealFeeConfigResult">
        <include refid="selectMealFeeConfigVo"/>
        where m.config_id = #{configId}
    </select>

    <select id="selectMealByLevelCode" resultMap="MealFeeConfigResult">
        <include refid="selectMealFeeConfigVo"/>
        where m.institution_id = #{institutionId}
        and m.meal_level_code = #{mealLevelCode}
    </select>

    <select id="selectAvailableMealsByInstitutionId" parameterType="Long" resultMap="MealFeeConfigResult">
        <include refid="selectMealFeeConfigVo"/>
        where m.institution_id = #{institutionId}
        and m.is_available = '1'
        order by m.sort_order, m.meal_level_code
    </select>

    <insert id="insertMealFeeConfig" parameterType="com.ruoyi.domain.pension.MealFeeConfig" useGeneratedKeys="true" keyProperty="configId">
        insert into meal_fee_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="institutionId != null">institution_id,</if>
            <if test="mealLevel != null and mealLevel != ''">meal_level,</if>
            <if test="mealLevelCode != null and mealLevelCode != ''">meal_level_code,</if>
            <if test="price != null">price,</if>
            <if test="mealDescription != null">meal_description,</if>
            <if test="isAvailable != null">is_available,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="institutionId != null">#{institutionId},</if>
            <if test="mealLevel != null and mealLevel != ''">#{mealLevel},</if>
            <if test="mealLevelCode != null and mealLevelCode != ''">#{mealLevelCode},</if>
            <if test="price != null">#{price},</if>
            <if test="mealDescription != null">#{mealDescription},</if>
            <if test="isAvailable != null">#{isAvailable},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            now()
        </trim>
    </insert>

    <update id="updateMealFeeConfig" parameterType="com.ruoyi.domain.pension.MealFeeConfig">
        update meal_fee_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="institutionId != null">institution_id = #{institutionId},</if>
            <if test="mealLevel != null and mealLevel != ''">meal_level = #{mealLevel},</if>
            <if test="mealLevelCode != null and mealLevelCode != ''">meal_level_code = #{mealLevelCode},</if>
            <if test="price != null">price = #{price},</if>
            <if test="mealDescription != null">meal_description = #{mealDescription},</if>
            <if test="isAvailable != null">is_available = #{isAvailable},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = now()
        </trim>
        where config_id = #{configId}
    </update>

    <delete id="deleteMealFeeConfigByConfigId" parameterType="Long">
        delete from meal_fee_config where config_id = #{configId}
    </delete>

    <delete id="deleteMealFeeConfigByConfigIds" parameterType="Long">
        delete from meal_fee_config where config_id in
        <foreach item="configId" collection="array" open="(" separator="," close=")">
            #{configId}
        </foreach>
    </delete>

</mapper>
