<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.AreaStreetMapper">

    <resultMap type="AreaStreet" id="AreaStreetResult">
        <result property="id"    column="id"    />
        <result property="areaCode"    column="area_code"    />
        <result property="areaName"    column="area_name"    />
        <result property="streetCode"    column="street_code"    />
        <result property="streetName"    column="street_name"    />
        <result property="sortOrder"    column="sort_order"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectAreaStreetVo">
        select id, area_code, area_name, street_code, street_name, sort_order, status, create_by, create_time, update_by, update_time, remark from area_street
    </sql>

    <select id="selectAreaStreetList" parameterType="AreaStreet" resultMap="AreaStreetResult">
        <include refid="selectAreaStreetVo"/>
        <where>
            <if test="areaCode != null  and areaCode != ''"> and area_code = #{areaCode}</if>
            <if test="areaName != null  and areaName != ''"> and area_name like concat('%', #{areaName}, '%')</if>
            <if test="streetCode != null  and streetCode != ''"> and street_code = #{streetCode}</if>
            <if test="streetName != null  and streetName != ''"> and street_name like concat('%', #{streetName}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by area_code, sort_order
    </select>

    <select id="selectAreaStreetById" parameterType="Long" resultMap="AreaStreetResult">
        <include refid="selectAreaStreetVo"/>
        where id = #{id}
    </select>

    <select id="selectAllAreas" resultMap="AreaStreetResult">
        select distinct area_code, area_name
        from area_street
        where status = '0'
        order by area_code
    </select>

    <select id="selectStreetsByAreaCode" parameterType="String" resultMap="AreaStreetResult">
        <include refid="selectAreaStreetVo"/>
        where area_code = #{areaCode} and status = '0' and street_name is not null and street_name != ''
        order by sort_order
    </select>

    <insert id="insertAreaStreet" parameterType="AreaStreet" useGeneratedKeys="true" keyProperty="id">
        insert into area_street
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="areaCode != null">area_code,</if>
            <if test="areaName != null">area_name,</if>
            <if test="streetCode != null">street_code,</if>
            <if test="streetName != null">street_name,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="areaCode != null">#{areaCode},</if>
            <if test="areaName != null">#{areaName},</if>
            <if test="streetCode != null">#{streetCode},</if>
            <if test="streetName != null">#{streetName},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateAreaStreet" parameterType="AreaStreet">
        update area_street
        <trim prefix="SET" suffixOverrides=",">
            <if test="areaCode != null">area_code = #{areaCode},</if>
            <if test="areaName != null">area_name = #{areaName},</if>
            <if test="streetCode != null">street_code = #{streetCode},</if>
            <if test="streetName != null">street_name = #{streetName},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAreaStreetById" parameterType="Long">
        delete from area_street where id = #{id}
    </delete>

    <delete id="deleteAreaStreetByIds" parameterType="String">
        delete from area_street where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>