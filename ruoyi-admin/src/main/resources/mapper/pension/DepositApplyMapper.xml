<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.pension.DepositApplyMapper">

    <resultMap type="DepositApply" id="DepositApplyResult">
        <result property="applyId"       column="apply_id"       />
        <result property="applyNo"       column="apply_no"       />
        <result property="elderId"       column="elder_id"       />
        <result property="institutionId" column="institution_id" />
        <result property="accountId"     column="account_id"     />
        <result property="applyAmount"   column="apply_amount"   />
        <result property="applyReason"   column="apply_reason"   />
        <result property="applyType"     column="apply_type"     />
        <result property="urgencyLevel"  column="urgency_level"  />
        <result property="purpose"       column="purpose"        />
        <result property="description"   column="description"    />
        <result property="expectedUseDate" column="expected_use_date" />
        <result property="attachments"   column="attachments"    />
        <result property="applyStatus"   column="apply_status"   />
        <result property="familyConfirmName"    column="family_confirm_name"   />
        <result property="familyRelation"       column="family_relation"       />
        <result property="familyPhone"          column="family_phone"          />
        <result property="familyApproveTime"    column="family_approve_time"   />
        <result property="familyApproveOpinion" column="family_approve_opinion" />
        <result property="approver"      column="approver"       />
        <result property="approveTime"   column="approve_time"   />
        <result property="approveRemark" column="approve_remark" />
        <result property="actualAmount"  column="actual_amount"  />
        <result property="useTime"       column="use_time"       />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
        <!-- 关联字段 -->
        <result property="elderName"        column="elder_name"        />
        <result property="institutionName"  column="institution_name"  />
        <result property="accountBalance"   column="deposit_balance"   />
        <result property="bedInfo"          column="bed_info"          />
    </resultMap>

    <sql id="selectDepositApplyVo">
        select apply_id, apply_no, elder_id, institution_id, account_id, apply_amount, apply_reason, apply_type, urgency_level, purpose, description, expected_use_date, attachments, apply_status, family_confirm_name, family_relation, family_phone, family_approve_time, family_approve_opinion, approver, approve_time, approve_remark, actual_amount, use_time, create_by, create_time, update_by, update_time, remark from deposit_apply
    </sql>

    <sql id="selectDepositApplyWithRelations">
        select da.apply_id, da.apply_no, da.elder_id, da.institution_id, da.account_id,
               da.apply_amount, da.apply_reason, da.apply_type, da.urgency_level,
               da.purpose, da.description, da.expected_use_date, da.attachments,
               da.apply_status, da.family_confirm_name, da.family_relation, da.family_phone,
               da.family_approve_time, da.family_approve_opinion,
               da.approver, da.approve_time, da.approve_remark, da.actual_amount, da.use_time,
               da.create_by, da.create_time, da.update_by, da.update_time, da.remark,
               ei.elder_name, pi.institution_name,
               ai.total_balance, ai.deposit_balance, ai.service_balance, ai.member_balance,
               CONCAT(bi.room_number, '-', bi.bed_number) as bed_info
        from deposit_apply da
        left join elder_info ei on da.elder_id = ei.elder_id
        left join pension_institution pi on da.institution_id = pi.institution_id
        left join account_info ai on da.account_id = ai.account_id
        left join (
            select elder_id, bed_id, allocation_id
            from bed_allocation
            where (elder_id, allocation_id) in (
                select elder_id, max(allocation_id)
                from bed_allocation
                group by elder_id
            )
        ) ba on da.elder_id = ba.elder_id
        left join bed_info bi on ba.bed_id = bi.bed_id
    </sql>

    <select id="selectDepositApplyList" parameterType="DepositApply" resultMap="DepositApplyResult">
        <include refid="selectDepositApplyWithRelations"/>
        <where>
            <!-- 数据权限过滤: 如果传入了currentUserId,则只查询该用户有权限的机构的押金申请 -->
            <if test="currentUserId != null">
                and da.institution_id IN (
                    SELECT institution_id FROM sys_user_institution WHERE user_id = #{currentUserId}
                )
            </if>
            <if test="applyNo != null  and applyNo != ''"> and da.apply_no like concat('%', #{applyNo}, '%')</if>
            <if test="elderId != null "> and da.elder_id = #{elderId}</if>
            <if test="institutionId != null "> and da.institution_id = #{institutionId}</if>
            <if test="applyType != null  and applyType != ''"> and da.apply_type = #{applyType}</if>
            <if test="urgencyLevel != null  and urgencyLevel != ''"> and da.urgency_level = #{urgencyLevel}</if>
            <if test="applyStatus != null  and applyStatus != ''"> and da.apply_status = #{applyStatus}</if>
            <if test="approver != null  and approver != ''"> and da.approver like concat('%', #{approver}, '%')</if>
        </where>
        order by da.create_time desc
    </select>

    <select id="selectDepositApplyByApplyId" parameterType="Long" resultMap="DepositApplyResult">
        <include refid="selectDepositApplyWithRelations"/>
        where da.apply_id = #{applyId}
    </select>

    <select id="selectDepositApplyByElderId" parameterType="Long" resultMap="DepositApplyResult">
        <include refid="selectDepositApplyWithRelations"/>
        where da.elder_id = #{elderId}
        order by da.create_time desc
    </select>

    <select id="selectDepositApplyByInstitutionId" parameterType="Long" resultMap="DepositApplyResult">
        <include refid="selectDepositApplyWithRelations"/>
        where da.institution_id = #{institutionId}
        order by da.create_time desc
    </select>

    <insert id="insertDepositApply" parameterType="DepositApply" useGeneratedKeys="true" keyProperty="applyId">
        insert into deposit_apply
