<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.pension.DepositApplyMapper">

    <resultMap type="DepositApply" id="DepositApplyResult">
        <result property="applyId"       column="apply_id"       />
        <result property="applyNo"       column="apply_no"       />
        <result property="elderId"       column="elder_id"       />
        <result property="institutionId" column="institution_id" />
        <result property="accountId"     column="account_id"     />
        <result property="applyAmount"   column="apply_amount"   />
        <result property="applyReason"   column="apply_reason"   />
        <result property="applyType"     column="apply_type"     />
        <result property="urgencyLevel"  column="urgency_level"  />
        <result property="applyStatus"   column="apply_status"   />
        <result property="approver"      column="approver"       />
        <result property="approveTime"   column="approve_time"   />
        <result property="approveRemark" column="approve_remark" />
        <result property="actualAmount"  column="actual_amount"  />
        <result property="useTime"       column="use_time"       />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
        <!-- 关联字段 -->
        <result property="elderName"        column="elder_name"        />
        <result property="institutionName"  column="institution_name"  />
        <result property="accountBalance"   column="total_balance"     />
    </resultMap>

    <sql id="selectDepositApplyVo">
        select apply_id, apply_no, elder_id, institution_id, account_id, apply_amount, apply_reason, apply_type, urgency_level, apply_status, approver, approve_time, approve_remark, actual_amount, use_time, create_by, create_time, update_by, update_time, remark from deposit_apply
    </sql>

    <sql id="selectDepositApplyWithRelations">
        select da.apply_id, da.apply_no, da.elder_id, da.institution_id, da.account_id,
               da.apply_amount, da.apply_reason, da.apply_type, da.urgency_level, da.apply_status,
               da.approver, da.approve_time, da.approve_remark, da.actual_amount, da.use_time,
               da.create_by, da.create_time, da.update_by, da.update_time, da.remark,
               ei.elder_name, pi.institution_name, ai.total_balance
        from deposit_apply da
        left join elder_info ei on da.elder_id = ei.elder_id
        left join pension_institution pi on da.institution_id = pi.institution_id
        left join account_info ai on da.account_id = ai.account_id
    </sql>

    <select id="selectDepositApplyList" parameterType="DepositApply" resultMap="DepositApplyResult">
        <include refid="selectDepositApplyWithRelations"/>
        <where>
            <if test="applyNo != null  and applyNo != ''"> and da.apply_no like concat('%', #{applyNo}, '%')</if>
            <if test="elderId != null "> and da.elder_id = #{elderId}</if>
            <if test="institutionId != null "> and da.institution_id = #{institutionId}</if>
            <if test="applyType != null  and applyType != ''"> and da.apply_type = #{applyType}</if>
            <if test="urgencyLevel != null  and urgencyLevel != ''"> and da.urgency_level = #{urgencyLevel}</if>
            <if test="applyStatus != null  and applyStatus != ''"> and da.apply_status = #{applyStatus}</if>
            <if test="approver != null  and approver != ''"> and da.approver like concat('%', #{approver}, '%')</if>
        </where>
        order by da.create_time desc
    </select>

    <select id="selectDepositApplyByApplyId" parameterType="Long" resultMap="DepositApplyResult">
        <include refid="selectDepositApplyWithRelations"/>
        where da.apply_id = #{applyId}
    </select>

    <select id="selectDepositApplyByElderId" parameterType="Long" resultMap="DepositApplyResult">
        <include refid="selectDepositApplyWithRelations"/>
        where da.elder_id = #{elderId}
        order by da.create_time desc
    </select>

    <select id="selectDepositApplyByInstitutionId" parameterType="Long" resultMap="DepositApplyResult">
        <include refid="selectDepositApplyWithRelations"/>
        where da.institution_id = #{institutionId}
        order by da.create_time desc
    </select>

    <insert id="insertDepositApply" parameterType="DepositApply" useGeneratedKeys="true" keyProperty="applyId">
        insert into deposit_apply
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="applyNo != null">apply_no,</if>
            <if test="elderId != null">elder_id,</if>
            <if test="institutionId != null">institution_id,</if>
            <if test="accountId != null">account_id,</if>
            <if test="applyAmount != null">apply_amount,</if>
            <if test="applyReason != null and applyReason != ''">apply_reason,</if>
            <if test="applyType != null">apply_type,</if>
            <if test="urgencyLevel != null">urgency_level,</if>
            <if test="applyStatus != null">apply_status,</if>
            <if test="approver != null and approver != ''">approver,</if>
            <if test="approveTime != null">approve_time,</if>
            <if test="approveRemark != null and approveRemark != ''">approve_remark,</if>
            <if test="actualAmount != null">actual_amount,</if>
            <if test="useTime != null">use_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null and remark != ''">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="applyNo != null">#{applyNo},</if>
            <if test="elderId != null">#{elderId},</if>
            <if test="institutionId != null">#{institutionId},</if>
            <if test="accountId != null">#{accountId},</if>
            <if test="applyAmount != null">#{applyAmount},</if>
            <if test="applyReason != null and applyReason != ''">#{applyReason},</if>
            <if test="applyType != null">#{applyType},</if>
            <if test="urgencyLevel != null">#{urgencyLevel},</if>
            <if test="applyStatus != null">#{applyStatus},</if>
            <if test="approver != null and approver != ''">#{approver},</if>
            <if test="approveTime != null">#{approveTime},</if>
            <if test="approveRemark != null and approveRemark != ''">#{approveRemark},</if>
            <if test="actualAmount != null">#{actualAmount},</if>
            <if test="useTime != null">#{useTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
         </trim>
    </insert>

    <update id="updateDepositApply" parameterType="DepositApply">
        update deposit_apply
        <trim prefix="SET" suffixOverrides=",">
            <if test="applyNo != null">apply_no = #{applyNo},</if>
            <if test="elderId != null">elder_id = #{elderId},</if>
            <if test="institutionId != null">institution_id = #{institutionId},</if>
            <if test="accountId != null">account_id = #{accountId},</if>
            <if test="applyAmount != null">apply_amount = #{applyAmount},</if>
            <if test="applyReason != null">apply_reason = #{applyReason},</if>
            <if test="applyType != null">apply_type = #{applyType},</if>
            <if test="urgencyLevel != null">urgency_level = #{urgencyLevel},</if>
            <if test="applyStatus != null">apply_status = #{applyStatus},</if>
            <if test="approver != null">approver = #{approver},</if>
            <if test="approveTime != null">approve_time = #{approveTime},</if>
            <if test="approveRemark != null">approve_remark = #{approveRemark},</if>
            <if test="actualAmount != null">actual_amount = #{actualAmount},</if>
            <if test="useTime != null">use_time = #{useTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where apply_id = #{applyId}
    </update>

    <delete id="deleteDepositApplyByApplyId" parameterType="Long">
        delete from deposit_apply where apply_id = #{applyId}
    </delete>

    <delete id="deleteDepositApplyByApplyIds" parameterType="String">
        delete from deposit_apply where apply_id in
        <foreach item="applyId" collection="array" open="(" separator="," close=")">
            #{applyId}
        </foreach>
    </delete>

</mapper>
