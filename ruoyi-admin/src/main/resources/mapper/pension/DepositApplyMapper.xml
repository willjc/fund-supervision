            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where apply_id = #{applyId}
    </update>

    <delete id="deleteDepositApplyByApplyId" parameterType="Long">
        delete from deposit_apply where apply_id = #{applyId}
    </delete>

    <delete id="deleteDepositApplyByApplyIds" parameterType="String">
        delete from deposit_apply where apply_id in
        <foreach item="applyId" collection="array" open="(" separator="," close=")">
            #{applyId}
        </foreach>
    </delete>

</mapper>
