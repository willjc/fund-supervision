            <if test="applyAmount != null">apply_amount,</if>
            <if test="applyReason != null and applyReason != ''">apply_reason,</if>
            <if test="applyType != null">apply_type,</if>
            <if test="urgencyLevel != null">urgency_level,</if>
            <if test="purpose != null and purpose != ''">purpose,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="expectedUseDate != null">expected_use_date,</if>
            <if test="attachments != null and attachments != ''">attachments,</if>
            <if test="applyStatus != null">apply_status,</if>
            <if test="familyConfirmName != null and familyConfirmName != ''">family_confirm_name,</if>
            <if test="familyRelation != null and familyRelation != ''">family_relation,</if>
            <if test="familyPhone != null and familyPhone != ''">family_phone,</if>
            <if test="familyApproveTime != null">family_approve_time,</if>
            <if test="familyApproveOpinion != null and familyApproveOpinion != ''">family_approve_opinion,</if>
            <if test="approver != null and approver != ''">approver,</if>
            <if test="approveTime != null">approve_time,</if>
            <if test="approveRemark != null and approveRemark != ''">approve_remark,</if>
            <if test="actualAmount != null">actual_amount,</if>
            <if test="useTime != null">use_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null and remark != ''">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="applyNo != null">#{applyNo},</if>
            <if test="elderId != null">#{elderId},</if>
            <if test="institutionId != null">#{institutionId},</if>
            <if test="accountId != null">#{accountId},</if>
            <if test="applyAmount != null">#{applyAmount},</if>
            <if test="applyReason != null and applyReason != ''">#{applyReason},</if>
            <if test="applyType != null">#{applyType},</if>
            <if test="urgencyLevel != null">#{urgencyLevel},</if>
            <if test="purpose != null and purpose != ''">#{purpose},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="expectedUseDate != null">#{expectedUseDate},</if>
            <if test="attachments != null and attachments != ''">#{attachments},</if>
            <if test="applyStatus != null">#{applyStatus},</if>
            <if test="familyConfirmName != null and familyConfirmName != ''">#{familyConfirmName},</if>
            <if test="familyRelation != null and familyRelation != ''">#{familyRelation},</if>
            <if test="familyPhone != null and familyPhone != ''">#{familyPhone},</if>
            <if test="familyApproveTime != null">#{familyApproveTime},</if>
            <if test="familyApproveOpinion != null and familyApproveOpinion != ''">#{familyApproveOpinion},</if>
            <if test="approver != null and approver != ''">#{approver},</if>
            <if test="approveTime != null">#{approveTime},</if>
            <if test="approveRemark != null and approveRemark != ''">#{approveRemark},</if>
            <if test="actualAmount != null">#{actualAmount},</if>
            <if test="useTime != null">#{useTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
         </trim>
    </insert>

    <update id="updateDepositApply" parameterType="DepositApply">
        update deposit_apply
        <trim prefix="SET" suffixOverrides=",">
            <if test="applyNo != null">apply_no = #{applyNo},</if>
            <if test="elderId != null">elder_id = #{elderId},</if>
            <if test="institutionId != null">institution_id = #{institutionId},</if>
            <if test="accountId != null">account_id = #{accountId},</if>
            <if test="applyAmount != null">apply_amount = #{applyAmount},</if>
            <if test="applyReason != null">apply_reason = #{applyReason},</if>
            <if test="applyType != null">apply_type = #{applyType},</if>
            <if test="urgencyLevel != null">urgency_level = #{urgencyLevel},</if>
            <if test="purpose != null">purpose = #{purpose},</if>
            <if test="description != null">description = #{description},</if>
            <if test="expectedUseDate != null">expected_use_date = #{expectedUseDate},</if>
            <if test="attachments != null">attachments = #{attachments},</if>
