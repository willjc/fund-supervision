<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.pension.TransferRuleConfigMapper">

    <resultMap type="TransferRuleConfig" id="TransferRuleConfigResult">
        <result property="ruleId"         column="rule_id"         />
        <result property="ruleName"       column="rule_name"       />
        <result property="transferCycle"  column="transfer_cycle"  />
        <result property="transferDay"    column="transfer_day"    />
        <result property="status"         column="status"          />
        <result property="remark"         column="remark"          />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
    </resultMap>

    <sql id="selectTransferRuleConfigVo">
        select rule_id, rule_name, transfer_cycle, transfer_day, status, remark, create_by, create_time, update_by, update_time
        from transfer_rule_config
    </sql>

    <select id="selectTransferRuleConfigList" parameterType="TransferRuleConfig" resultMap="TransferRuleConfigResult">
        <include refid="selectTransferRuleConfigVo"/>
        <where>
            <if test="ruleName != null and ruleName != ''">
                AND rule_name like concat('%', #{ruleName}, '%')
            </if>
            <if test="transferCycle != null and transferCycle != ''">
                AND transfer_cycle = #{transferCycle}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectTransferRuleConfigByRuleId" parameterType="Long" resultMap="TransferRuleConfigResult">
        <include refid="selectTransferRuleConfigVo"/>
        where rule_id = #{ruleId}
    </select>

    <insert id="insertTransferRuleConfig" parameterType="TransferRuleConfig" useGeneratedKeys="true" keyProperty="ruleId">
        insert into transfer_rule_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ruleName != null and ruleName != ''">rule_name,</if>
            <if test="transferCycle != null and transferCycle != ''">transfer_cycle,</if>
            <if test="transferDay != null">transfer_day,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="ruleName != null and ruleName != ''">#{ruleName},</if>
            <if test="transferCycle != null and transferCycle != ''">#{transferCycle},</if>
            <if test="transferDay != null">#{transferDay},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateTransferRuleConfig" parameterType="TransferRuleConfig">
        update transfer_rule_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="ruleName != null and ruleName != ''">rule_name = #{ruleName},</if>
            <if test="transferCycle != null and transferCycle != ''">transfer_cycle = #{transferCycle},</if>
            <if test="transferDay != null">transfer_day = #{transferDay},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where rule_id = #{ruleId}
    </update>

    <delete id="deleteTransferRuleConfigByRuleId" parameterType="Long">
        delete from transfer_rule_config where rule_id = #{ruleId}
    </delete>

    <delete id="deleteTransferRuleConfigByRuleIds" parameterType="Long">
        delete from transfer_rule_config where rule_id in
        <foreach item="ruleId" collection="array" open="(" separator="," close=")">
            #{ruleId}
        </foreach>
    </delete>

</mapper>
