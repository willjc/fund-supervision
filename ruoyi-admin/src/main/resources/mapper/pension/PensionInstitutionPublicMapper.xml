    <sql id="selectPensionInstitutionPublicVo">
        select
            p.public_id,
            i.institution_id,
            p.institution_intro,
            p.service_scope,
            p.service_features,
            p.land_area,
            p.building_area,
            p.environment_imgs,
            p.main_picture,
            p.rating,
            p.fee_range_min,
            p.fee_range_max,
            p.nursing_fee_min,
            p.nursing_fee_max,
            p.bed_fee_min,
            p.bed_fee_max,
            p.meal_fee_min,
            p.meal_fee_max,
            p.accept_elder_type,
            p.is_published,
            p.room_facilities,
            p.basic_facilities,
            p.park_facilities,
            p.life_facilities,
            p.medical_facilities,
            p.daily_services,
            p.create_by,
            p.create_time,
            p.update_by,
            p.update_time,
            i.institution_name,
            i.credit_code,
            i.record_number,
            i.actual_address,
            i.bed_count,
            i.supervise_account,
            i.fee_range,
            i.contact_person,
            i.contact_phone,
            i.contact_email
        from pension_institution i
        left join pension_institution_public p on i.institution_id = p.institution_id
    </sql>

    <select id="selectPensionInstitutionPublicList" parameterType="PensionInstitutionPublic" resultMap="PensionInstitutionPublicResult">
        <include refid="selectPensionInstitutionPublicVo"/>
        <where>
            <!-- 只查询已入驻的机构 -->
            and i.status = '1'
            <!-- 数据权限过滤: 机构管理员只能查看自己关联的机构 -->
            <if test="currentUserId != null">
                and i.institution_id in (
                    select institution_id from sys_user_institution where user_id = #{currentUserId}
                )
            </if>
            <if test="institutionId != null "> and i.institution_id = #{institutionId}</if>
            <if test="institutionName != null  and institutionName != ''"> and i.institution_name like concat('%', #{institutionName}, '%')</if>
            <if test="isPublished != null  and isPublished != ''"> and p.is_published = #{isPublished}</if>
            <if test="rating != null  and rating != ''"> and p.rating = #{rating}</if>
        </where>
        order by p.update_time desc, p.create_time desc, i.create_time desc
    </select>

    <select id="selectPensionInstitutionPublicByPublicId" parameterType="Long" resultMap="PensionInstitutionPublicResult">
        <include refid="selectPensionInstitutionPublicVo"/>
        where p.public_id = #{publicId}
    </select>

    <select id="selectPensionInstitutionPublicByInstitutionId" parameterType="Long" resultMap="PensionInstitutionPublicResult">
        <include refid="selectPensionInstitutionPublicVo"/>
        where p.institution_id = #{institutionId}
    </select>

