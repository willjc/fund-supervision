<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.UserFavoriteMapper">

    <resultMap type="UserFavorite" id="UserFavoriteResult">
        <result property="favoriteId"    column="favorite_id"    />
        <result property="userId"    column="user_id"    />
        <result property="institutionId"    column="institution_id"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectUserFavoriteVo">
        select favorite_id, user_id, institution_id, create_time from user_favorite
    </sql>

    <select id="selectUserFavoriteList" parameterType="UserFavorite" resultMap="UserFavoriteResult">
        <include refid="selectUserFavoriteVo"/>
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="institutionId != null "> and institution_id = #{institutionId}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectUserFavoriteByFavoriteId" parameterType="Long" resultMap="UserFavoriteResult">
        <include refid="selectUserFavoriteVo"/>
        where favorite_id = #{favoriteId}
    </select>

    <select id="selectByUserIdAndInstitutionId" resultMap="UserFavoriteResult">
        <include refid="selectUserFavoriteVo"/>
        where user_id = #{userId} and institution_id = #{institutionId}
    </select>

    <insert id="insertUserFavorite" parameterType="UserFavorite" useGeneratedKeys="true" keyProperty="favoriteId">
        insert into user_favorite
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="institutionId != null">institution_id,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="institutionId != null">#{institutionId},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateUserFavorite" parameterType="UserFavorite">
        update user_favorite
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="institutionId != null">institution_id = #{institutionId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where favorite_id = #{favoriteId}
    </update>

    <delete id="deleteUserFavoriteByFavoriteId" parameterType="Long">
        delete from user_favorite where favorite_id = #{favoriteId}
    </delete>

    <delete id="deleteUserFavoriteByFavoriteIds" parameterType="String">
        delete from user_favorite where favorite_id in
        <foreach item="favoriteId" collection="array" open="(" separator="," close=")">
            #{favoriteId}
        </foreach>
    </delete>

    <delete id="deleteByUserIdAndInstitutionId">
        delete from user_favorite where user_id = #{userId} and institution_id = #{institutionId}
    </delete>

</mapper>