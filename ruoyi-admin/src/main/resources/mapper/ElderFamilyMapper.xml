<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.ElderFamilyMapper">

    <resultMap type="ElderFamily" id="ElderFamilyResult">
        <result property="familyId"       column="family_id"       />
        <result property="userId"         column="user_id"         />
        <result property="elderId"        column="elder_id"        />
        <result property="relationType"   column="relation_type"   />
        <result property="relationName"   column="relation_name"   />
        <result property="isDefault"      column="is_default"      />
        <result property="isMainContact"  column="is_main_contact" />
        <result property="status"         column="status"          />
        <result property="createTime"     column="create_time"     />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
        <result property="nickName"       column="nick_name"       />
        <result property="phonenumber"    column="phonenumber"     />
        <result property="elderName"      column="elder_name"      />
    </resultMap>

    <sql id="selectElderFamilyVo">
        select ef.family_id, ef.user_id, ef.elder_id, ef.relation_type, ef.relation_name,
               ef.is_default, ef.is_main_contact, ef.status, ef.create_time, ef.update_time, ef.remark,
               u.nick_name, u.phonenumber, ei.elder_name
        from elder_family ef
        left join sys_user u on ef.user_id = u.user_id
        left join elder_info ei on ef.elder_id = ei.elder_id
    </sql>

    <select id="selectElderFamilyList" parameterType="ElderFamily" resultMap="ElderFamilyResult">
        <include refid="selectElderFamilyVo"/>
        <where>
            <if test="userId != null">and ef.user_id = #{userId}</if>
            <if test="elderId != null">and ef.elder_id = #{elderId}</if>
            <if test="relationType != null and relationType != ''">and ef.relation_type = #{relationType}</if>
            <if test="status != null and status != ''">and ef.status = #{status}</if>
        </where>
        order by ef.is_main_contact desc, ef.is_default desc, ef.create_time asc
    </select>

    <select id="selectElderFamilyById" parameterType="Long" resultMap="ElderFamilyResult">
        <include refid="selectElderFamilyVo"/>
        where ef.family_id = #{familyId}
    </select>

    <insert id="insertElderFamily" parameterType="ElderFamily" useGeneratedKeys="true" keyProperty="familyId">
        insert into elder_family
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="elderId != null">elder_id,</if>
            <if test="relationType != null and relationType != ''">relation_type,</if>
            <if test="relationName != null and relationName != ''">relation_name,</if>
            <if test="isDefault != null">is_default,</if>
            <if test="isMainContact != null">is_main_contact,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="elderId != null">#{elderId},</if>
            <if test="relationType != null and relationType != ''">#{relationType},</if>
            <if test="relationName != null and relationName != ''">#{relationName},</if>
            <if test="isDefault != null">#{isDefault},</if>
            <if test="isMainContact != null">#{isMainContact},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateElderFamily" parameterType="ElderFamily">
        update elder_family
        <trim prefix="SET" suffixOverrides=",">
            <if test="relationType != null and relationType != ''">relation_type = #{relationType},</if>
            <if test="relationName != null and relationName != ''">relation_name = #{relationName},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            <if test="isMainContact != null">is_main_contact = #{isMainContact},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where family_id = #{familyId}
    </update>

    <delete id="deleteElderFamilyById" parameterType="Long">
        delete from elder_family where family_id = #{familyId}
    </delete>

    <delete id="deleteElderFamilyByIds" parameterType="Long">
        delete from elder_family where family_id in
        <foreach item="familyId" collection="array" open="(" separator="," close=")">
            #{familyId}
        </foreach>
    </delete>

</mapper>
