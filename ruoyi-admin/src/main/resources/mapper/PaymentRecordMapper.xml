<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.PaymentRecordMapper">

    <resultMap type="PaymentRecord" id="PaymentRecordResult">
        <result property="paymentId"    column="payment_id"    />
        <result property="paymentNo"    column="payment_no"    />
        <result property="orderId"     column="order_id"     />
        <result property="orderNo"     column="order_no"     />
        <result property="elderId"     column="elder_id"     />
        <result property="institutionId"    column="institution_id"    />
        <result property="paymentAmount"    column="payment_amount"    />
        <result property="paymentMethod"    column="payment_method"    />
        <result property="paymentStatus"    column="payment_status"    />
        <result property="paymentTime"    column="payment_time"    />
        <result property="transactionId"    column="transaction_id"    />
        <result property="gatewayResponse"    column="gateway_response"    />
        <result property="operator"     column="operator"     />
        <result property="createBy"   column="create_by"   />
        <result property="createTime" column="create_time" />
        <result property="updateBy"   column="update_by"   />
        <result property="updateTime" column="update_time" />
        <result property="remark"     column="remark"     />
        <result property="elderName" column="elder_name" />
        <result property="institutionName" column="institution_name" />
    </resultMap>

    <sql id="selectPaymentRecordVo">
        select p.payment_id, p.payment_no, p.order_id, p.elder_id, p.institution_id,
               p.payment_amount, p.payment_method, p.payment_status, p.payment_time,
               p.transaction_id, p.gateway_response, p.operator, p.create_by, p.create_time,
               p.update_by, p.update_time, p.remark,
               e.elder_name, i.institution_name, o.order_no
        from payment_record p
        left join elder_info e on p.elder_id = e.elder_id
        left join pension_institution i on p.institution_id = i.institution_id
        left join order_info o on p.order_id = o.order_id
    </sql>

    <select id="selectPaymentRecordList" parameterType="PaymentRecord" resultMap="PaymentRecordResult">
        <include refid="selectPaymentRecordVo"/>
        <where>
            <if test="paymentNo != null  and paymentNo != ''"> and p.payment_no like concat('%', #{paymentNo}, '%')</if>
            <if test="orderId != null "> and p.order_id = #{orderId}</if>
            <if test="elderId != null "> and p.elder_id = #{elderId}</if>
            <if test="institutionId != null "> and p.institution_id = #{institutionId}</if>
            <if test="paymentMethod != null  and paymentMethod != ''"> and p.payment_method = #{paymentMethod}</if>
            <if test="paymentStatus != null  and paymentStatus != ''"> and p.payment_status = #{paymentStatus}</if>
            <if test="elderName != null  and elderName != ''"> and e.elder_name like concat('%', #{elderName}, '%')</if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                and date_format(p.payment_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                and date_format(p.payment_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
        order by p.payment_time desc
    </select>

    <select id="selectPaymentRecordByPaymentId" parameterType="Long" resultMap="PaymentRecordResult">
        <include refid="selectPaymentRecordVo"/>
        where p.payment_id = #{paymentId}
    </select>

    <select id="selectPaymentRecordByPaymentNo" parameterType="String" resultMap="PaymentRecordResult">
        <include refid="selectPaymentRecordVo"/>
        where p.payment_no = #{paymentNo}
    </select>

    <select id="selectPaymentsByOrderId" parameterType="Long" resultMap="PaymentRecordResult">
        <include refid="selectPaymentRecordVo"/>
        where p.order_id = #{orderId}
        order by p.payment_time desc
    </select>

    <select id="selectPaymentsByElderId" parameterType="Long" resultMap="PaymentRecordResult">
        <include refid="selectPaymentRecordVo"/>
        where p.elder_id = #{elderId}
        order by p.payment_time desc
    </select>

    <select id="selectPaymentAmountTotal" parameterType="PaymentRecord" resultType="java.math.BigDecimal">
        select COALESCE(sum(p.payment_amount), 0)
        from payment_record p
        left join elder_info e on p.elder_id = e.elder_id
        <where>
            <if test="paymentStatus != null  and paymentStatus != ''"> and p.payment_status = #{paymentStatus}</if>
            <if test="elderId != null "> and p.elder_id = #{elderId}</if>
            <if test="institutionId != null "> and p.institution_id = #{institutionId}</if>
            <if test="elderName != null  and elderName != ''"> and e.elder_name like concat('%', #{elderName}, '%')</if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                and date_format(p.payment_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                and date_format(p.payment_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
    </select>

    <insert id="insertPaymentRecord" parameterType="PaymentRecord" useGeneratedKeys="true" keyProperty="paymentId">
        insert into payment_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="paymentNo != null and paymentNo != ''">payment_no,</if>
            <if test="orderId != null">order_id,</if>
            <if test="elderId != null">elder_id,</if>
            <if test="institutionId != null">institution_id,</if>
            <if test="paymentAmount != null">payment_amount,</if>
            <if test="paymentMethod != null and paymentMethod != ''">payment_method,</if>
            <if test="paymentStatus != null">payment_status,</if>
            <if test="paymentTime != null">payment_time,</if>
            <if test="transactionId != null and transactionId != ''">transaction_id,</if>
            <if test="gatewayResponse != null and gatewayResponse != ''">gateway_response,</if>
            <if test="operator != null and operator != ''">operator,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="paymentNo != null and paymentNo != ''">#{paymentNo},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="elderId != null">#{elderId},</if>
            <if test="institutionId != null">#{institutionId},</if>
            <if test="paymentAmount != null">#{paymentAmount},</if>
            <if test="paymentMethod != null and paymentMethod != ''">#{paymentMethod},</if>
            <if test="paymentStatus != null">#{paymentStatus},</if>
            <if test="paymentTime != null">#{paymentTime},</if>
            <if test="transactionId != null and transactionId != ''">#{transactionId},</if>
            <if test="gatewayResponse != null and gatewayResponse != ''">#{gatewayResponse},</if>
            <if test="operator != null and operator != ''">#{operator},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updatePaymentRecord" parameterType="PaymentRecord">
        update payment_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="paymentNo != null and paymentNo != ''">payment_no = #{paymentNo},</if>
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="elderId != null">elder_id = #{elderId},</if>
            <if test="institutionId != null">institution_id = #{institutionId},</if>
            <if test="paymentAmount != null">payment_amount = #{paymentAmount},</if>
            <if test="paymentMethod != null and paymentMethod != ''">payment_method = #{paymentMethod},</if>
            <if test="paymentStatus != null">payment_status = #{paymentStatus},</if>
            <if test="paymentTime != null">payment_time = #{paymentTime},</if>
            <if test="transactionId != null and transactionId != ''">transaction_id = #{transactionId},</if>
            <if test="gatewayResponse != null and gatewayResponse != ''">gateway_response = #{gatewayResponse},</if>
            <if test="operator != null and operator != ''">operator = #{operator},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where payment_id = #{paymentId}
    </update>

    <delete id="deletePaymentRecordByPaymentId" parameterType="Long">
        delete from payment_record where payment_id = #{paymentId}
    </delete>

    <delete id="deletePaymentRecordByPaymentIds" parameterType="String">
        delete from payment_record where payment_id in
        <foreach item="paymentId" collection="array" open="(" separator="," close=")">
            #{paymentId}
        </foreach>
    </delete>

</mapper>